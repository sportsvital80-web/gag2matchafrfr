_G.MatchaCleanup = function()
    ScriptActive = false; running = false
    pcall(function() mouse1release() end)
    for _, obj in ipairs(drawObjs) do pcall(function() obj:Remove() end) end
    print("[PanAuto] Cleanup done")
end

