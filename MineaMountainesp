local TierColors = {
    Common    = Color3.fromRGB(180,180,180),
    Uncommon  = Color3.fromRGB(50,220,50),
    Rare      = Color3.fromRGB(50,150,255),
    Epic      = Color3.fromRGB(150,50,220),
    Legendary = Color3.fromRGB(255,150,0),
    Mythic    = Color3.fromRGB(255,50,50),
    Divine    = Color3.fromRGB(255,220,50),
}
local dynamicColors = {}
local colorList = {
    Color3.fromRGB(0,255,255), Color3.fromRGB(255,0,255), Color3.fromRGB(255,255,0),
    Color3.fromRGB(255,128,0), Color3.fromRGB(0,255,128), Color3.fromRGB(128,0,255),
}
local colorIndex = 1
local function getTierColor(n)
    for name, col in pairs(TierColors) do
        if string.find(string.lower(n), string.lower(name)) then return col end
    end
    if dynamicColors[n] then return dynamicColors[n] end
    local c = colorList[colorIndex]; dynamicColors[n] = c
    colorIndex = (colorIndex % #colorList) + 1
    return c
end

-- ======================================================================
-- CRYSTAL DATA EXTRACTION (CACHED)
-- ======================================================================
local dataCache = {}   -- [mainPart] = { TierName, Value, Weight }

local INVALID_NAMES = {
    proximityprompt=true,touchinterest=true,weight=true,value=true,
    crystalglow=true,magicaura=true,unknown=true,part=true,meshpart=true,
    attachment=true,glow=true,aura=true,emitter=true,particle=true,
    sound=true,billboardgui=true,textlabel=true,selectionbox=true,
    light=true,pointlight=true,spotlight=true,surfacegui=true,
    decals=true,decal=true,texture=true,weld=true,motor6d=true,
    alignposition=true,alignorientation=true,things=true,crystals=true,
    workspace=true,crystal=true,
}
local function isInvalidTier(t)
    if not t or t == "" then return true end
    local lo = string.lower(t)
    if tonumber(lo) then return true end
    if INVALID_NAMES[lo] then return true end
    return string.find(lo,"prompt") or string.find(lo,"interest") or
           string.find(lo,"glow")   or string.find(lo,"aura")     or
           string.find(lo,"weld")   or string.find(lo,"particle") or
           string.find(lo,"light")  or string.find(lo,"effect")
end

local function safeReadValue(instance)
    if not instance then return nil end
    local ok, val = pcall(function() return instance.Value end)
    return ok and val or nil
end

local function getCrystalData(part)
    if dataCache[part] then
        local d = dataCache[part]
        return d.TierName, d.Value, d.Weight
    end
    local parent = part.Parent
    -- TierName
    local tier = part:GetAttribute("TierName") or part:GetAttribute("Tier")
    if not tier and parent then tier = parent:GetAttribute("TierName") or parent:GetAttribute("Tier") end
    if not tier then
        local c = part:FindFirstChild("TierName") or part:FindFirstChild("Tier")
        if not c and parent then c = parent:FindFirstChild("TierName") or parent:FindFirstChild("Tier") end
        if c then
            local cv = safeReadValue(c)
            tier = cv and tostring(cv) or c.Name
        elseif parent and parent ~= game.Workspace and parent.Name ~= "Crystals" and parent.Name ~= "Things" then
            tier = parent.Name
        else tier = part.Name end
    end
    tier = tostring(tier)
    -- Value
    local val = part:GetAttribute("Value") or part:GetAttribute("Price") or part:GetAttribute("Worth")
    if not val and parent then val = parent:GetAttribute("Value") or parent:GetAttribute("Price") or parent:GetAttribute("Worth") end
    if val then val = tonumber(val) or 0
    else
        local c = part:FindFirstChild("Value") or part:FindFirstChild("Price") or part:FindFirstChild("Worth")
        if not c and parent then c = parent:FindFirstChild("Value") or parent:FindFirstChild("Price") or parent:FindFirstChild("Worth") end
        local cv = safeReadValue(c)
        val = cv and tonumber(cv) or 0
    end
    -- Weight
    local wgt = part:GetAttribute("Weight") or part:GetAttribute("Mass")
    if not wgt and parent then wgt = parent:GetAttribute("Weight") or parent:GetAttribute("Mass") end
    if wgt then wgt = tonumber(wgt) or 0
    else
        local c = part:FindFirstChild("Weight") or part:FindFirstChild("Mass")
        if not c and parent then c = parent:FindFirstChild("Weight") or parent:FindFirstChild("Mass") end
        local cv = safeReadValue(c)
        wgt = cv and tonumber(cv) or 0
    end

    local d = { TierName = tier, Value = val, Weight = wgt }
    dataCache[part] = d
    return tier, val, wgt
end

