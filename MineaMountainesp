-- ======================================================================
-- FEATURE SYSTEM
-- ======================================================================
local F          = {}
local featureMap = {}
local uniqueTiers = {}

local function updateFeatureMap()
    table.clear(featureMap)
    for _,f in ipairs(F) do featureMap[f.key] = f.value end
end
local function feat(tab,key,label,kind,value)
    local f = {tab=tab,key=key,label=label,kind=kind,value=value}
    table.insert(F,f); featureMap[key]=value; return f
end
local function getFeatureValue(key,default)
    local v = featureMap[key]
    if v ~= nil then return v end
    return default
end

feat(1,"esp_enabled","ENABLE CRYSTAL ESP","toggle",true)
feat(1,"rescan","RESCAN CRYSTALS","action",nil)
feat(2,"min_value","MIN VALUE: 0","action",0)
feat(2,"max_dist","MAX DISTANCE: 500","action",500)
feat(2,"max_weight","MAX WEIGHT: 1000","action",1000)

_G.selected_tp_tier = _G.selected_tp_tier or nil

local function rebuildTierFeatures()
    for i=#F,1,-1 do
        local f=F[i]
        if f.tab==3 or (f.tab==1 and (string.sub(f.key,1,7)=="tp_sel_" or f.key=="tp_action")) then
            table.remove(F,i)
        end
    end
    for tierName in pairs(uniqueTiers) do
        feat(3,"tier_"..tierName,"SHOW "..string.upper(tierName),"toggle",true)
    end
    feat(3,"select_all_tiers","SELECT ALL TIERS","action",nil)
    feat(3,"clear_all_tiers","CLEAR ALL TIERS","action",nil)

    local found = false
    for t in pairs(uniqueTiers) do
        if _G.selected_tp_tier == t then found=true; break end
    end
    if not found then _G.selected_tp_tier = next(uniqueTiers) end

    for t in pairs(uniqueTiers) do
        feat(1,"tp_sel_"..t,"TARGET: "..string.upper(t),"toggle",(_G.selected_tp_tier==t))
    end
    if _G.selected_tp_tier then feat(1,"tp_action","TP TO NEAREST","action",nil) end
    updateFeatureMap()
end

local function isTierAllowed(n)
    return getFeatureValue("tier_"..n, false)
end

-- ======================================================================
-- ESP DRAWING POOL
-- All Drawing objects for crystals are created ONCE here and
-- NEVER removed unless the crystal literally leaves the workspace folder.
-- The Heartbeat only moves/shows/hides them.
-- ======================================================================
-- activeCrystals[entity] = { part, tier, value, weight, Box, Text,
--                             bv=false, tv=false,  -- last visible state
--                             lb=0,lbx=0,lby=0,lbsz=0,  -- last box cache
--                             lt="",ltx=0,lty=0 }  -- last text cache
local activeCrystals = {}

local function makeESPForCrystal(entity, part, tier, val, wgt)
    if activeCrystals[entity] then return end  -- already tracked

    local color = getTierColor(tier)
    local box = Drawing.new("Square")
    box.Filled     = false
    box.Thickness  = 1
    box.Color      = color
    box.Visible    = false

    local txt = Drawing.new("Text")
    txt.Size    = 13
    txt.Font    = Drawing.Fonts.System
    txt.Center  = true
    txt.Outline = true
    txt.Color   = color
    txt.Visible = false

    activeCrystals[entity] = {
        part   = part,
        tier   = tier,
        value  = val,
        weight = wgt,
        Box    = box,
        Text   = txt,
        -- cached state (raw numbers/strings to avoid Vector2/Color3 allocs)
        bv=false, tv=false,
        lbx=0, lby=0, lbsz=0,
        lcr=-1, lcg=-1, lcb=-1,
        ltx=0, lty=0, lt=""
    }

    if tier and tier ~= "Unknown" and not uniqueTiers[tier] then
        uniqueTiers[tier] = true
        rebuildTierFeatures()
        uiNeedsUpdate = true
    end
end

local function removeESPForCrystal(entity)
    local d = activeCrystals[entity]
    if not d then return end
    d.Box:Remove()
    d.Text:Remove()
    activeCrystals[entity] = nil
    -- clean data cache
    if entity.Parent == nil then dataCache[d.part] = nil end
end

-- ======================================================================
-- INITIAL SCAN (runs once, then events take over)
-- ======================================================================
local watchConns = {}   -- folder ChildAdded / ChildRemoved connections

local function addCrystalEntity(child)
    if activeCrystals[child] then return end
    local part = child:FindFirstChild("MeshPart") or child:FindFirstChild("Part")
                 or (child:IsA("BasePart") and child)
    if not part then return end
    local tier, val, wgt = getCrystalData(part)
    if isInvalidTier(tier) then return end
    makeESPForCrystal(child, part, tier, val, wgt)
end

local function initialScan()
    local folder = game.Workspace:FindFirstChild("Things")
    local crystalsFolder = folder and folder:FindFirstChild("Crystals")
    if not crystalsFolder then
        warn("[Crystal ESP] Crystals folder not found – will retry in 2s")
        task.delay(2, initialScan)
        return
    end

    -- Disconnect old watchers if rescan is called
    for _,c in ipairs(watchConns) do pcall(function() c:Disconnect() end) end
    table.clear(watchConns)

    -- Remove drawings for any previously tracked entities no longer present
    local current = {}
    for _,child in ipairs(crystalsFolder:GetChildren()) do current[child]=true end
    for entity in pairs(activeCrystals) do
        if not current[entity] then removeESPForCrystal(entity) end
    end

    -- Add all current crystals
    for child in pairs(current) do
        addCrystalEntity(child)
    end

    rebuildTierFeatures()
    uiNeedsUpdate = true
    print(string.format("[Crystal ESP] Scan complete. %d crystals registered.", (function()
        local n=0; for _ in pairs(activeCrystals) do n=n+1 end; return n
    end)()))
end

-- ======================================================================
-- ESP HEARTBEAT RENDERER
-- Only does: WorldToScreen + raw number comparisons + set properties.
-- Zero table/object allocation per frame.
-- ======================================================================
local function updateESP()
    local enabled = getFeatureValue("esp_enabled", true)
    local cam     = workspace.CurrentCamera
    local camPos  = cam and cam.Position

    if not enabled or not camPos then
        -- hide everything quickly
        for _,d in pairs(activeCrystals) do
            if d.bv then d.bv=false; d.Box.Visible=false end
            if d.tv then d.tv=false; d.Text.Visible=false end
        end
        return
    end

    local minVal  = getFeatureValue("min_value", 0)
    local maxDist = getFeatureValue("max_dist", 500)
    local maxWgt  = getFeatureValue("max_weight", 1000)

    local toRemove = nil  -- lazy allocation

    for entity, d in pairs(activeCrystals) do
        -- Safety: crystal collected / destroyed
        if not entity.Parent or not d.part.Parent then
            if not toRemove then toRemove = {} end
            toRemove[#toRemove+1] = entity
        else
            -- Filter: value / weight / tier toggle
            local show = d.value >= minVal and d.weight <= maxWgt and isTierAllowed(d.tier)
            if show then
                local px,py,pz = d.part.Position.X, d.part.Position.Y, d.part.Position.Z
                local dist = math.sqrt((px-camPos.X)^2 + (py-camPos.Y)^2 + (pz-camPos.Z)^2)
                if dist > maxDist then show = false end
                if show then
                    local screenPos, onScreen = WorldToScreen(d.part.Position)
                    if onScreen and screenPos then
                        local bsz = math.floor(math.clamp(4500/dist, 6, 100))
                        local sx   = math.floor(screenPos.X)
                        local sy   = math.floor(screenPos.Y)
                        local half = math.floor(bsz*0.5)
                        local bx   = sx-half
                        local by   = sy-half

                        -- Box
                        local col = getTierColor(d.tier)
                        local cr,cg,cb = col.R,col.G,col.B
                        if d.lbsz ~= bsz then
                            d.lbsz = bsz
                            d.Box.Size = Vector2.new(bsz,bsz)
                        end
                        if d.lbx ~= bx or d.lby ~= by then
                            d.lbx=bx; d.lby=by
                            d.Box.Position = Vector2.new(bx,by)
                        end
                        if d.lcr ~= cr or d.lcg ~= cg or d.lcb ~= cb then
                            d.lcr=cr; d.lcg=cg; d.lcb=cb
                            d.Box.Color  = col
                            d.Text.Color = col
                        end
                        if not d.bv then d.bv=true; d.Box.Visible=true end

                        -- Text
                        local di  = math.floor(dist)
                        local wi  = math.floor(d.weight)
                        local tstr= d.tier.."\n$"..d.value.." ("..wi.." kg)\n["..di.." m]"
                        if d.lt ~= tstr then
                            d.lt = tstr
                            d.Text.Text = tstr
                        end
                        local tx = sx
                        local ty = sy+half+2
                        if d.ltx ~= tx or d.lty ~= ty then
                            d.ltx=tx; d.lty=ty
                            d.Text.Position = Vector2.new(tx,ty)
                        end
                        if not d.tv then d.tv=true; d.Text.Visible=true end
                    else
                        show = false
                    end
                end
            end
            if not show then
                if d.bv then d.bv=false; d.Box.Visible=false end
                if d.tv then d.tv=false; d.Text.Visible=false end
            end
        end
    end

    if toRemove then
        for _,e in ipairs(toRemove) do removeESPForCrystal(e) end
    end
end

-- ======================================================================
-- TELEPORT
-- ======================================================================
local function doTeleport(hrp, pos)
    hrp.CFrame = CFrame.new(pos.X, pos.Y+3, pos.Z, 1,0,0, 0,1,0, 0,0,1)
end
local function teleportToNearestSelected()
    local targetTier = _G.selected_tp_tier
    if not targetTier then
        pcall(function() if notify then notify("No target rarity selected!","Crystal TP",3) end end)
        return
    end
    local char = LP.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then
        pcall(function() if notify then notify("HumanoidRootPart not found!","Crystal TP",3) end end)
        return
    end
    local myPos  = hrp.Position
    local minVal = getFeatureValue("min_value", 0)
    local maxDist= getFeatureValue("max_dist",  500)
    local maxWgt = getFeatureValue("max_weight",1000)
    local nearest, nearDist = nil, math.huge
    for _, d in pairs(activeCrystals) do
        if d.tier == targetTier and d.value >= minVal and d.weight <= maxWgt then
            local dist = (d.part.Position - myPos).Magnitude
            if dist <= maxDist and dist < nearDist then
                nearDist = dist; nearest = d.part
            end
        end
    end
    if nearest then
        pcall(doTeleport, hrp, nearest.Position)
        pcall(function()
            if notify then notify(string.format("Teleported to nearest %s (%.1fm)", targetTier, nearDist),"Crystal TP",3) end
        end)
    else
        pcall(function() if notify then notify("No "..targetTier.." matching filters found!","Crystal TP",3) end end)
    end
end

