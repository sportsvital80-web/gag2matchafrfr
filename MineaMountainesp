-- ======================================================================
-- UI THREAD — owns its thread entirely
-- ======================================================================
task.spawn(function()
    while ScriptActive do
        task.wait(0.016)  -- ~60fps for UI, smooth as butter

        local mx,my = 0,0
        if Mouse then mx,my = Mouse.X,Mouse.Y end
        local m1 = safeKey(0x01)

        -- Keyboard (typing mode)
        if typing then
            for vk,char in pairs(pollKeys) do
                local down = safeKey(vk)
                if down and not lastKeyState[vk] then
                    if char == "enter" then
                        typing = false
                        local num = tonumber(typeBuffer) or 0
                        for _,f in ipairs(F) do
                            if f.key == typingKey then
                                f.value = num
                                featureMap[f.key] = num
                                if typingKey == "min_value"  then f.label = "MIN VALUE: "..num
                                elseif typingKey == "max_dist"  then f.label = "MAX DISTANCE: "..num
                                elseif typingKey == "max_weight" then f.label = "MAX WEIGHT: "..num
                                end
                                break
                            end
                        end
                        typeBuffer=""; typingKey=nil; uiNeedsUpdate=true
                    elseif char == "escape" then
                        typing = false
                        for _,f in ipairs(F) do
                            if f.key == typingKey then
                                if typingKey == "min_value"  then f.label = "MIN VALUE: "..f.value
                                elseif typingKey == "max_dist"  then f.label = "MAX DISTANCE: "..f.value
                                elseif typingKey == "max_weight" then f.label = "MAX WEIGHT: "..f.value
                                end
                                break
                            end
                        end
                        typeBuffer=""; typingKey=nil; uiNeedsUpdate=true
                    elseif char == "backspace" then
                        if #typeBuffer > 0 then typeBuffer = string.sub(typeBuffer,1,#typeBuffer-1) end
                    else
                        if #typeBuffer < 10 then typeBuffer = typeBuffer..char end
                    end
                end
                lastKeyState[vk] = down
            end
        end

        -- Mouse click
        if m1 and not lastM1 then
            -- Tab click
            for i=1,#TabNames do
                local tx2 = uiPos.X+10+((i-1)*125)
                if mx>=tx2 and mx<=tx2+110 and my>=uiPos.Y+34 and my<=uiPos.Y+64 then
                    activeTab=i; uiNeedsUpdate=true
                end
            end
            -- Feature click
            local slot=0
            for _,f in ipairs(F) do
                if f.tab == activeTab then
                    slot=slot+1
                    if slot<=MAXS then
                        local yy=uiPos.Y+75+((slot-1)*26)
                        if mx>=uiPos.X+10 and mx<=uiPos.X+uiSize.X-10 and my>=yy-2 and my<=yy+24 then
                            if f.kind=="toggle" then
                                if string.sub(f.key,1,7)=="tp_sel_" then
                                    _G.selected_tp_tier=string.sub(f.key,8)
                                    rebuildTierFeatures()
                                else
                                    f.value = not f.value
                                    featureMap[f.key] = f.value
                                end
                                uiNeedsUpdate=true
                            elseif f.kind=="action" then
                                if f.key=="min_value" or f.key=="max_dist" or f.key=="max_weight" then
                                    if not typing then
                                        typing=true; typingKey=f.key
                                        typeBuffer=tostring(f.value)
                                        f.label="TYPING: "..typeBuffer.."_"
                                        uiNeedsUpdate=true
                                    end
                                elseif f.key=="tp_action" then
                                    teleportToNearestSelected()
                                elseif f.key=="rescan" then
                                    task.spawn(initialScan)
                                    pcall(function() if notify then notify("Rescanning...","Crystal ESP",2) end end)
                                    uiNeedsUpdate=true
                                elseif f.key=="select_all_tiers" then
                                    for _,tf in ipairs(F) do
                                        if tf.tab==3 and string.sub(tf.key,1,5)=="tier_" then
                                            tf.value=true; featureMap[tf.key]=true
                                        end
                                    end; uiNeedsUpdate=true
                                elseif f.key=="clear_all_tiers" then
                                    for _,tf in ipairs(F) do
                                        if tf.tab==3 and string.sub(tf.key,1,5)=="tier_" then
                                            tf.value=false; featureMap[tf.key]=false
                                        end
                                    end; uiNeedsUpdate=true
                                end
                            end
                        end
                    end
                end
            end
            -- Drag start
            if mx>=uiPos.X and mx<=uiPos.X+uiSize.X and my>=uiPos.Y and my<=uiPos.Y+30 then
                dragging=true; dragOff=Vector2.new(mx-uiPos.X,my-uiPos.Y)
            end
        end

        if dragging then
            if m1 then
                local np=Vector2.new(mx-dragOff.X,my-dragOff.Y)
                if np.X~=uiPos.X or np.Y~=uiPos.Y then uiPos=np; uiNeedsUpdate=true end
            else dragging=false end
        end
        lastM1=m1

        -- Render UI (only when something changed or cursor blinks)
        if uiNeedsUpdate or typing then
            uiNeedsUpdate = false

            sq(Shadow, "shd", Vector2.new(uiPos.X-3,uiPos.Y-3), Vector2.new(uiSize.X+6,uiSize.Y+6), true, nil, 0.35)
            sq(MainBG, "bg",  uiPos, uiSize, true)
            sq(TopBar, "top", uiPos, Vector2.new(uiSize.X,30), true)
            sq(AccLine,"acc", Vector2.new(uiPos.X,uiPos.Y+30), Vector2.new(uiSize.X,2), true, GREEN)
            tx(TitleTxt,"ttl","MATCHA // CRYSTAL ESP",Vector2.new(uiPos.X+10,uiPos.Y+8),GREEN,true)

            for i,lbl in ipairs(TabTxts) do
                tx(lbl,"tab"..i, TabNames[i], Vector2.new(uiPos.X+20+((i-1)*125),uiPos.Y+40),
                   (i==activeTab) and GREEN or DIM, true)
            end

            if typing then
                local cursor=(math.floor(tick()*2.5)%2==0) and "_" or ""
                for _,f in ipairs(F) do
                    if f.key==typingKey then f.label="TYPING: "..typeBuffer..cursor end
                end
            end

            local slot=0
            for _,f in ipairs(F) do
                if f.tab==activeTab then
                    slot=slot+1
                    if slot<=MAXS then
                        local yy=uiPos.Y+75+((slot-1)*26)
                        local pre=(f.kind=="action") and ">> " or "> "
                        local str=pre..tostring(f.label)
                        local col=(f.kind=="action") and GREEN or (f.value and LTGRN or GREY)
                        tx(SLabel[slot],"l"..slot, str, Vector2.new(uiPos.X+16,yy), col, true)
                        local isT=(f.kind=="toggle")
                        local cp=Vector2.new(uiPos.X+uiSize.X-22,yy+7)
                        ci(SCheck[slot],"k"..slot, cp, isT, 8, GREEN)
                        ci(SFill[slot], "f"..slot, cp, (isT and f.value==true), 5, GREEN)
                    end
                end
            end
            for i=slot+1,MAXS do setSlotVisible(i,false) end

            tx(StatusTxt,"sts",
               "ESP: "..(getFeatureValue("esp_enabled",true) and "ACTIVE" or "DISABLED")..
               " | Crystals: "..(function() local n=0; for _ in pairs(activeCrystals) do n=n+1 end; return n end)(),
               Vector2.new(uiPos.X+10,uiPos.Y+uiSize.Y-16), DARK, true)
        end
    end
end)

-- ======================================================================
-- ESP HEARTBEAT — lean as possible, just move existing Drawing objects
-- ======================================================================
local lastESP = 0
local conn = RunService.Heartbeat:Connect(function()
    if not ScriptActive then return end
    local now = tick()
    if now - lastESP < 0.05 then return end  -- 20fps cap
    lastESP = now
    local ok,err = pcall(updateESP)
    if not ok then warn("[Crystal ESP] Heartbeat error: "..tostring(err)) end
end)

-- ======================================================================
-- STARTUP & CLEANUP
-- ======================================================================
initialScan()

_G.CrystalESPCleanup = function()
    ScriptActive = false
    task.wait(0.05)
    for _,c in ipairs(watchConns) do pcall(function() c:Disconnect() end) end
    pcall(function() conn:Disconnect() end)
    for _,d in pairs(activeCrystals) do
        pcall(function() d.Box:Remove() end)
        pcall(function() d.Text:Remove() end)
    end
    for _,obj in ipairs(drawObjs) do
        pcall(function() obj:Remove() end)
    end
    table.clear(activeCrystals)
    table.clear(dataCache)
    print("[Crystal ESP] Cleanup complete.")
end

pcall(function()
    if notify then notify("Crystal ESP Loaded!","Crystal ESP",4) end
end)
