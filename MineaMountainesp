local pollKeys = { [0x0D]="enter", [0x08]="backspace", [0x1B]="escape" }
for i=0x30,0x39 do pollKeys[i]=tostring(i-0x30) end
for i=0x60,0x69 do pollKeys[i]=tostring(i-0x60) end
local lastKeyState = {}
for vk in pairs(pollKeys) do lastKeyState[vk]=false end

-- ======================================================================
-- UI DRAW HELPERS (integer-keyed state cache, no userdata weak keys)
-- ======================================================================
local sqC,ciC,txC = {},{},{}

local function sq(obj,id, pos,size, vis, col, tr)
    local c=sqC[id]; if not c then c={}; sqC[id]=c end
    if c.v~=vis then c.v=vis; obj.Visible=vis end
    if not vis then return end
    if c.px~=pos.X or c.py~=pos.Y then c.px=pos.X; c.py=pos.Y; obj.Position=pos end
    if c.sx~=size.X or c.sy~=size.Y then c.sx=size.X; c.sy=size.Y; obj.Size=size end
    if col then
        if c.cr~=col.R or c.cg~=col.G or c.cb~=col.B then
            c.cr=col.R; c.cg=col.G; c.cb=col.B; obj.Color=col
        end
    end
    if tr and c.tr~=tr then c.tr=tr; obj.Transparency=tr end
end
local function ci(obj,id, pos, vis, r, col)
    local c=ciC[id]; if not c then c={}; ciC[id]=c end
    if c.v~=vis then c.v=vis; obj.Visible=vis end
    if not vis then return end
    if c.px~=pos.X or c.py~=pos.Y then c.px=pos.X; c.py=pos.Y; obj.Position=pos end
    if r and c.r~=r then c.r=r; obj.Radius=r end
    if col then
        if c.cr~=col.R or c.cg~=col.G or c.cb~=col.B then
            c.cr=col.R; c.cg=col.G; c.cb=col.B; obj.Color=col
        end
    end
end
local function tx(obj,id, str, pos, col, vis)
    local c=txC[id]; if not c then c={}; txC[id]=c end
    if c.v~=vis then c.v=vis; obj.Visible=vis end
    if not vis then return end
    if c.t~=str then c.t=str; obj.Text=str end
    if c.px~=pos.X or c.py~=pos.Y then c.px=pos.X; c.py=pos.Y; obj.Position=pos end
    if col then
        if c.cr~=col.R or c.cg~=col.G or c.cb~=col.B then
            c.cr=col.R; c.cg=col.G; c.cb=col.B; obj.Color=col
        end
    end
end
local function setSlotVisible(slot, vis)
    local cl=txC["l"..slot]; if not cl then cl={}; txC["l"..slot]=cl end
    if cl.v~=vis then cl.v=vis; SLabel[slot].Visible=vis end
    local cc=ciC["k"..slot]; if not cc then cc={}; ciC["k"..slot]=cc end
    if cc.v~=vis then cc.v=vis; SCheck[slot].Visible=vis end
    local cf=ciC["f"..slot]; if not cf then cf={}; ciC["f"..slot]=cf end
    if cf.v~=vis then cf.v=vis; SFill[slot].Visible=vis end
end

